{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "import"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "rules": {
    "no-unused-vars": "warn",
    "typescript/no-explicit-any": "off",
    "unicorn/no-thenable": "off"
  },
  "ignorePatterns": ["dist/", "node_modules/"]
}
