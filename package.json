    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
    "ai": "^6",
    "exceljs": "^4",
    "html-to-text": "^9",
