    "mammoth": "^1",
    "papaparse": "^5.5.3",
    "unpdf": "^1.4.0"
  },
  "devDependencies": {
    "@types/html-to-text": "^9",
    "@types/mailparser": "^3",
    "@types/node": "^25",
    "@types/papaparse": "^5.5.2",
    "lintcn": "^0.7.0",
    "oxfmt": "latest",
    "oxlint": "latest",
    "tsup": "^8",
    "typescript": "^5"
  },
  "peerDependencies": {},
  "peerDependenciesMeta": {}
