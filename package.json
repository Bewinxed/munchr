{
  "name": "munchr",
  "version": "0.3.3",
  "description": "Any document + schema in, streamed structured JSON out.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bewinxed/munchr"
  },
  "files": [
    "dist",
    "skills"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
